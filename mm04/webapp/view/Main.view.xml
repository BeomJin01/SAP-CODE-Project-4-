<mvc:View
    controllerName="code.t4.ui5.mm04.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    displayBlock="true"
>
    <Page
        id="mainPage"
        title="{i18n>mainTitle}"
        showHeader="true"
    >
        <!-- 헤더 우측 대시보드 버튼 -->
        <headerContent>
            <Button
                id="btnDashboard"
                icon="sap-icon://horizontal-bar-chart"
                text="{i18n>btnDashboard}"
                press=".onNavToDashboard"
            />
        </headerContent>

        <content>
            <!-- 조회 조건 패널 (SimpleForm) -->
            <Panel
                id="searchPanel"
                headerText="{i18n>searchCondition}"
                expandable="false"
            >
                <content>
                    <f:SimpleForm
                        id="searchForm"
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="2"
                        labelSpanL="2"
                        labelSpanM="3"
                        labelSpanS="12"
                        emptySpanXL="4"
                        emptySpanL="4"
                        emptySpanM="4"
                        columnsXL="2"
                        columnsL="2"
                        columnsM="1"
                    >
                        <!-- Row 1: MPS 실행 ID From ~ To -->
                        <f:content>
                            <Label
                                text="{i18n>lblMpsRunId}"
                                labelFor="inputRunIdFrom"
                            />
                            <HBox alignItems="Center">
                                <Input
                                    id="inputRunIdFrom"
                                    placeholder="From"
                                    maxLength="12"
                                    width="12rem"
                                    value="{viewModel>/searchRunIdFrom}"
                                />
                                <Text
                                    text="~"
                                    class="sapUiSmallMarginBeginEnd"
                                />
                                <Input
                                    id="inputRunIdTo"
                                    placeholder="To"
                                    maxLength="12"
                                    width="12rem"
                                    value="{viewModel>/searchRunIdTo}"
                                />
                                <!-- F4 서치헬프 버튼 -->
                                <Button
                                    icon="sap-icon://value-help"
                                    press=".onMpsRunIdF4"
                                    tooltip="MPS 실행 ID 검색"
                                />
                            </HBox>

                            <!-- Row 1 우측: 플랜트 -->
                            <Label
                                text="{i18n>lblWerks}"
                                labelFor="inputWerks"
                            />
                            <HBox alignItems="Center">
                                <Input
                                    id="inputWerks"
                                    placeholder="플랜트"
                                    maxLength="4"
                                    width="8rem"
                                    value="{viewModel>/searchWerks}"
                                />
                                <Button
                                    icon="sap-icon://value-help"
                                    press=".onPlantF4"
                                    tooltip="플랜트 검색"
                                />
                            </HBox>

                            <!-- Row 2: 자재코드 -->
                            <Label
                                text="{i18n>lblMatnr}"
                                labelFor="inputMatnr"
                            />
                            <HBox alignItems="Center">
                                <Input
                                    id="inputMatnr"
                                    placeholder="자재코드"
                                    maxLength="18"
                                    width="16rem"
                                    value="{viewModel>/searchMatnr}"
                                />
                                <Button
                                    icon="sap-icon://value-help"
                                    press=".onMaterialF4"
                                    tooltip="자재 검색"
                                />
                                <Text
                                    id="txtMaktx"
                                    text="{viewModel>/searchMaktx}"
                                    class="sapUiSmallMarginBegin"
                                />
                            </HBox>

                            <!-- Row 2 우측: 실행상태 -->
                            <Label
                                text="{i18n>lblStatus}"
                                labelFor="cbStatus"
                            />
                            <Select
                                id="cbStatus"
                                selectedKey="{viewModel>/searchStatus}"
                                width="12rem"
                            >
                                <items>
                                    <core:Item
                                        xmlns:core="sap.ui.core"
                                        key=""
                                        text="{i18n>lblAll}"
                                    />
                                    <core:Item
                                        xmlns:core="sap.ui.core"
                                        key="EC"
                                        text="{i18n>statusEC}"
                                    />
                                    <core:Item
                                        xmlns:core="sap.ui.core"
                                        key="EF"
                                        text="{i18n>statusEF}"
                                    />
                                    <core:Item
                                        xmlns:core="sap.ui.core"
                                        key="CN"
                                        text="{i18n>statusCN}"
                                    />
                                </items>
                            </Select>

                            <!-- Row 3: 계획 시작일 DateRangeSelection -->
                            <Label
                                text="{i18n>lblPlanStartDate}"
                                labelFor="drsStartDate"
                            />
                            <DateRangeSelection
                                id="drsStartDate"
                                displayFormat="yyyy.MM.dd"
                                valueFormat="yyyy-MM-dd"
                                placeholder="YYYY.MM.DD ~ YYYY.MM.DD"
                                width="20rem"
                            />

                            <!-- Row 3 우측: 계획 종료일 DateRangeSelection -->
                            <Label
                                text="{i18n>lblPlanEndDate}"
                                labelFor="drsEndDate"
                            />
                            <DateRangeSelection
                                id="drsEndDate"
                                displayFormat="yyyy.MM.dd"
                                valueFormat="yyyy-MM-dd"
                                placeholder="YYYY.MM.DD ~ YYYY.MM.DD"
                                width="20rem"
                            />
                        </f:content>
                    </f:SimpleForm>

                    <!-- 조회/초기화 버튼 -->
                    <HBox
                        justifyContent="Center"
                        class="sapUiSmallMarginTop"
                    >
                        <Button
                            id="btnSearch"
                            text="{i18n>btnSearch}"
                            type="Emphasized"
                            icon="sap-icon://search"
                            press=".onSearch"
                        />
                        <Button
                            id="btnReset"
                            text="{i18n>btnReset}"
                            icon="sap-icon://clear-filter"
                            press=".onReset"
                            class="sapUiSmallMarginBegin"
                        />
                    </HBox>
                </content>
            </Panel>

            <!-- 결과 테이블 영역 -->
            <VBox class="sapUiSmallMarginTop">
                <!-- 테이블 상단 툴바 (건수 + 엑셀/새로고침) -->
                <HBox
                    justifyContent="SpaceBetween"
                    alignItems="Center"
                    class="sapUiSmallMarginBeginEnd"
                >
                    <Text
                        id="txtResultCount"
                        text="총 0건"
                    />
                    <HBox>
                        <Button
                            id="btnExcel"
                            icon="sap-icon://excel-attachment"
                            text="{i18n>btnExcel}"
                            press=".onExcelExport"
                        />
                        <Button
                            id="btnRefresh"
                            icon="sap-icon://refresh"
                            text="{i18n>btnRefresh}"
                            press=".onRefresh"
                            class="sapUiSmallMarginBegin"
                        />
                    </HBox>
                </HBox>

                <!-- 결과 테이블 -->
                <Table
                    id="mainTable"
                    items="{mainTableModel>/items}"
                    noDataText="{i18n>msgNoData}"
                    growing="true"
                    growingThreshold="50"
                    sticky="ColumnHeaders"
                >
                    <columns>
                        <Column
                            width="4rem"
                            hAlign="Center"
                        >
                            <Text text="{i18n>colStatus}" />
                        </Column>
                        <Column width="8rem">
                            <Text text="{i18n>colStatusDetail}" />
                        </Column>
                        <Column width="12rem">
                            <Text text="{i18n>colMpsRunId}" />
                        </Column>
                        <Column width="6rem">
                            <Text text="{i18n>colWerks}" />
                        </Column>
                        <Column width="10rem">
                            <Text text="{i18n>colPlantName}" />
                        </Column>
                        <Column width="12rem">
                            <Text text="{i18n>colMatnr}" />
                        </Column>
                        <Column width="16rem">
                            <Text text="{i18n>colMaktx}" />
                        </Column>
                        <Column
                            width="10rem"
                            hAlign="Center"
                        >
                            <Text text="{i18n>colPlanStartDate}" />
                        </Column>
                        <Column
                            width="10rem"
                            hAlign="Center"
                        >
                            <Text text="{i18n>colPlanEndDate}" />
                        </Column>
                        <Column
                            width="10rem"
                            hAlign="Center"
                        >
                            <Text text="{i18n>colRunDate}" />
                        </Column>
                        <Column width="8rem">
                            <Text text="{i18n>colErnam}" />
                        </Column>
                        <Column
                            width="10rem"
                            hAlign="Center"
                        >
                            <Text text="{i18n>colEarliestWaDate}" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem
                            id="mainTableItem"
                            type="Navigation"
                            press=".onRowPress"
                        >
                            <cells>
                                <!-- 상태 LED (ObjectStatus icon) -->
                                <ObjectStatus
                                    icon="{path: 'mainTableModel>Status', formatter: '.formatter.statusIcon'}"
                                    state="{path: 'mainTableModel>Status', formatter: '.formatter.statusState'}"
                                />

                                <!-- 상태상세 (아이템 기준) -->
                                <ObjectStatus
                                    text="{path: 'mainTableModel>ItemStatus', formatter: '.formatter.itemStatusText'}"
                                    state="{path: 'mainTableModel>ItemStatus', formatter: '.formatter.itemStatusState'}"
                                />

                                <!-- MPS 실행 ID (클릭 → Detail) -->
                                <Link
                                    text="{mainTableModel>MpsRunId}"
                                    press=".onRowPress"
                                />

                                <Text text="{mainTableModel>Werks}" />
                                <Text text="{mainTableModel>PlantName}" />
                                <Text text="{mainTableModel>Matnr}" />
                                <Text text="{mainTableModel>Maktx}" />

                                <Text
                                    text="{path: 'mainTableModel>PlanStartDate', formatter: '.formatter.formatDate'}"
                                />
                                <Text
                                    text="{path: 'mainTableModel>PlanEndDate', formatter: '.formatter.formatDate'}"
                                />
                                <Text
                                    text="{path: 'mainTableModel>RunDate', formatter: '.formatter.formatDate'}"
                                />

                                <Text text="{mainTableModel>Ernam}" />
                                <Text
                                    text="{path: 'mainTableModel>EarliestWaDate', formatter: '.formatter.formatDate'}"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
