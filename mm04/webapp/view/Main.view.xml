<mvc:View
    controllerName="code.t4.ui5.mm04.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    displayBlock="true"
>
    <!-- View1: MPS 실행 목록 조회 화면 -->
    <Page
        id="mainPage"
        title="{i18n>mainTitle}"
    >
        <!-- 헤더 우측: 대시보드 이동 버튼 -->
        <headerContent>
            <Button
                id="btnDashboard"
                icon="sap-icon://horizontal-bar-chart"
                text="{i18n>btnDashboard}"
                press=".onNavToDashboard"
            />
        </headerContent>

        <content>
            <!-- 조회 조건 패널 -->
            <Panel
                id="searchPanel"
                headerText="{i18n>searchCondition}"
                expandable="false"
            >
                <content>
                    <l:Grid
                        id="searchGrid"
                        hSpacing="1"
                        vSpacing="0"
                        width="100%"
                    >
                        <l:content>
                            <!-- ===== 1열: MPS 실행 ID / 플랜트 / 자재코드 ===== -->
                            <VBox
                                width="100%"
                                class="sapUiSmallMarginTop sapUiSmallMarginBottom"
                            >
                                <layoutData>
                                    <l:GridData span="XL5 L5 M12 S12" />
                                </layoutData>

                                <!-- Row1: MPS 실행 ID From ~ To + F4 -->
                                <HBox
                                    alignItems="Center"
                                    class="sapUiSmallMarginBottom"
                                >
                                    <Label
                                        text="{i18n>lblMpsRunId}"
                                        width="7rem"
                                        textAlign="Right"
                                    />
                                    <Input
                                        id="inputRunIdFrom"
                                        placeholder="From"
                                        maxLength="12"
                                        width="7rem"
                                        value="{viewModel>/searchRunIdFrom}"
                                        class="sapUiSmallMarginBegin"
                                        submit=".onSearch"
                                    />
                                    <Button
                                        icon="sap-icon://value-help"
                                        press=".onMpsRunIdFromF4"
                                        tooltip="MPS 실행 ID From 검색"
                                    />
                                    <Text
                                        text="~"
                                        class="sapUiSmallMarginBeginEnd"
                                    />
                                    <Input
                                        id="inputRunIdTo"
                                        placeholder="To"
                                        maxLength="12"
                                        width="7rem"
                                        value="{viewModel>/searchRunIdTo}"
                                        submit=".onSearch"
                                    />
                                    <Button
                                        icon="sap-icon://value-help"
                                        press=".onMpsRunIdToF4"
                                        tooltip="MPS 실행 ID To 검색"
                                    />
                                </HBox>

                                <!-- Row2: 플랜트 + F4 -->
                                <HBox
                                    alignItems="Center"
                                    class="sapUiSmallMarginBottom"
                                >
                                    <Label
                                        text="{i18n>lblWerks}"
                                        width="7rem"
                                        textAlign="Right"
                                    />
                                    <Input
                                        id="inputWerks"
                                        placeholder="플랜트"
                                        maxLength="4"
                                        width="7rem"
                                        value="{viewModel>/searchWerks}"
                                        class="sapUiSmallMarginBegin"
                                        submit=".onSearch"
                                    />
                                    <Button
                                        icon="sap-icon://value-help"
                                        press=".onPlantF4"
                                        tooltip="플랜트 검색"
                                    />
                                </HBox>

                                <!-- Row3: 자재코드 + F4 + 자재명 표시 -->
                                <HBox
                                    alignItems="Center"
                                    class="sapUiSmallMarginBottom"
                                >
                                    <Label
                                        text="{i18n>lblMatnr}"
                                        width="7rem"
                                        textAlign="Right"
                                    />
                                    <Input
                                        id="inputMatnr"
                                        placeholder="자재코드"
                                        maxLength="18"
                                        width="11rem"
                                        value="{viewModel>/searchMatnr}"
                                        class="sapUiSmallMarginBegin"
                                        liveChange=".onMatnrLiveChange"
                                        submit=".onSearch"
                                    />
                                    <Button
                                        icon="sap-icon://value-help"
                                        press=".onMaterialF4"
                                        tooltip="자재 검색"
                                    />
                                    <!-- F4 선택 후 자재명 텍스트 표시 -->
                                    <Text
                                        id="txtMaktx"
                                        text="{viewModel>/searchMaktx}"
                                        class="sapUiSmallMarginBegin"
                                    />
                                </HBox>
                            </VBox>

                            <!-- ===== 2열: 상태상세 / 실행상태 ===== -->
                            <VBox
                                width="100%"
                                class="sapUiSmallMarginTop sapUiSmallMarginBottom"
                            >
                                <layoutData>
                                    <l:GridData span="XL3 L3 M6 S12" />
                                </layoutData>

                                <!-- Row1: 상태상세 Select -->
                                <HBox
                                    alignItems="Center"
                                    class="sapUiSmallMarginBottom"
                                >
                                    <Label
                                        text="{i18n>lblStatusDetail}"
                                        width="5rem"
                                        textAlign="Right"
                                    />
                                    <Select
                                        id="cbStatusDetail"
                                        selectedKey="{viewModel>/searchStatusDetail}"
                                        width="8rem"
                                        class="sapUiSmallMarginBegin"
                                    >
                                        <items>
                                            <core:Item
                                                xmlns:core="sap.ui.core"
                                                key=""
                                                text="{i18n>lblAll}"
                                            />
                                            <!-- 확정포함: Status=EC + EarliestWaDate 없음 -->
                                            <core:Item
                                                xmlns:core="sap.ui.core"
                                                key="EC_ONLY"
                                                text="{i18n>statusDetailEC}"
                                            />
                                            <!-- 승인대기: Status=EC + EarliestWaDate 있음 -->
                                            <core:Item
                                                xmlns:core="sap.ui.core"
                                                key="WA"
                                                text="{i18n>statusDetailWA}"
                                            />
                                            <!-- 계획취소: Status=EF 또는 CN -->
                                            <core:Item
                                                xmlns:core="sap.ui.core"
                                                key="CN"
                                                text="{i18n>statusDetailCN}"
                                            />
                                        </items>
                                    </Select>
                                </HBox>

                                <!-- Row2: 실행상태 Select -->
                                <HBox
                                    alignItems="Center"
                                    class="sapUiSmallMarginBottom"
                                >
                                    <Label
                                        text="{i18n>lblStatus}"
                                        width="5rem"
                                        textAlign="Right"
                                    />
                                    <Select
                                        id="cbStatus"
                                        selectedKey="{viewModel>/searchStatus}"
                                        width="8rem"
                                        class="sapUiSmallMarginBegin"
                                    >
                                        <items>
                                            <core:Item
                                                xmlns:core="sap.ui.core"
                                                key=""
                                                text="{i18n>lblAll}"
                                            />
                                            <core:Item
                                                xmlns:core="sap.ui.core"
                                                key="EC"
                                                text="{i18n>statusEC}"
                                            />
                                            <core:Item
                                                xmlns:core="sap.ui.core"
                                                key="EF"
                                                text="{i18n>statusEF}"
                                            />
                                            <core:Item
                                                xmlns:core="sap.ui.core"
                                                key="CN"
                                                text="{i18n>statusCN}"
                                            />
                                        </items>
                                    </Select>
                                </HBox>
                            </VBox>

                            <!-- ===== 3열: 계획시작일 / 계획종료일 / 조회·초기화 ===== -->
                            <!--
            width="100%" + HBox width="100%" + justifyContent="End"
            → 조회/초기화 버튼이 3열 오른쪽 끝에 고정
        -->
                            <VBox
                                width="100%"
                                class="sapUiSmallMarginTop sapUiSmallMarginBottom"
                            >
                                <layoutData>
                                    <l:GridData span="XL4 L4 M6 S12" />
                                </layoutData>

                                <!-- Row1: 계획 시작일 -->
                                <HBox
                                    alignItems="Center"
                                    class="sapUiSmallMarginBottom"
                                >
                                    <Label
                                        text="{i18n>lblPlanStartDate}"
                                        width="6rem"
                                        textAlign="Right"
                                    />
                                    <DateRangeSelection
                                        id="drsStartDate"
                                        displayFormat="yyyy.MM.dd"
                                        valueFormat="yyyy-MM-dd"
                                        placeholder="YYYY.MM.DD ~ YYYY.MM.DD"
                                        width="18rem"
                                        class="sapUiSmallMarginBegin"
                                    />
                                </HBox>

                                <!-- Row2: 계획 종료일 -->
                                <HBox
                                    alignItems="Center"
                                    class="sapUiSmallMarginBottom"
                                >
                                    <Label
                                        text="{i18n>lblPlanEndDate}"
                                        width="6rem"
                                        textAlign="Right"
                                    />
                                    <DateRangeSelection
                                        id="drsEndDate"
                                        displayFormat="yyyy.MM.dd"
                                        valueFormat="yyyy-MM-dd"
                                        placeholder="YYYY.MM.DD ~ YYYY.MM.DD"
                                        width="18rem"
                                        class="sapUiSmallMarginBegin"
                                    />
                                </HBox>

                                <!-- Row3: 조회/초기화 버튼 → 3열 오른쪽 끝 고정 -->
                                <!--
                VBox width="100%" → HBox width="100%" → justifyContent="End"
                세 조건이 모두 충족되어야 버튼이 오른쪽 끝에 위치
            -->
                                <HBox
                                    justifyContent="End"
                                    alignItems="Center"
                                    width="100%"
                                    class="sapUiSmallMarginBottom"
                                >
                                    <Button
                                        id="btnSearch"
                                        text="{i18n>btnSearch}"
                                        type="Emphasized"
                                        icon="sap-icon://search"
                                        press=".onSearch"
                                    />
                                    <Button
                                        id="btnReset"
                                        text="{i18n>btnReset}"
                                        icon="sap-icon://clear-filter"
                                        press=".onReset"
                                        class="sapUiSmallMarginBegin"
                                    />
                                </HBox>
                            </VBox>
                        </l:content>
                    </l:Grid>
                </content>
            </Panel>

            <!-- 결과 테이블 영역 -->
            <VBox class="sapUiSmallMarginTop">
                <!-- 테이블 상단: 건수(좌) + 새로고침(우) -->
                <HBox
                    justifyContent="SpaceBetween"
                    alignItems="Center"
                    class="sapUiSmallMarginBeginEnd"
                >
                    <!-- SAP GUI MPS 프로그램과 동일한 형식 -->
                    <Text
                        id="txtResultCount"
                        text="MPS 실행 목록: 0건"
                    />
                    <Button
                        id="btnRefresh"
                        icon="sap-icon://refresh"
                        text="{i18n>btnRefresh}"
                        press=".onRefresh"
                    />
                </HBox>

                <!--
                    결과 테이블
                    width 미지정 → 컬럼 너비 자동 조절
                    growing: 50건씩 추가 로드
                    sticky: 스크롤 시 컬럼 헤더 고정
                -->
                <Table
                    id="mainTable"
                    items="{mainTableModel>/items}"
                    noDataText="{i18n>msgNoData}"
                    growing="true"
                    growingThreshold="50"
                    sticky="ColumnHeaders"
                >
                    <columns>
                        <!-- 상태: 헤더 STATUS 기준 LED -->
                        <!-- EC=파랑(Information), EF=빨강(Error), CN=회색(None) -->
                        <Column hAlign="Center">
                            <Text text="{i18n>colStatus}" />
                        </Column>

                        <!-- 상태상세: 헤더 STATUS 기준 텍스트 -->
                        <!-- EC=확정포함(초록), EF/CN=계획취소(빨강) -->
                        <Column>
                            <Text text="{i18n>colStatusDetail}" />
                        </Column>

                        <!-- 실행상태: 헤더 STATUS 텍스트 -->
                        <!-- 실행완료/실행실패/실행취소 -->
                        <Column>
                            <Text text="{i18n>colStatusText}" />
                        </Column>

                        <!-- MPS 실행 ID: 클릭 시 Detail 화면 이동 -->
                        <Column>
                            <Text text="{i18n>colMpsRunId}" />
                        </Column>

                        <Column hAlign="Center">
                            <Text text="{i18n>colPlanStartDate}" />
                        </Column>

                        <Column hAlign="Center">
                            <Text text="{i18n>colPlanEndDate}" />
                        </Column>

                        <Column>
                            <Text text="{i18n>colWerks}" />
                        </Column>

                        <Column>
                            <Text text="{i18n>colPlantName}" />
                        </Column>

                        <Column>
                            <Text text="{i18n>colMatnr}" />
                        </Column>

                        <Column>
                            <Text text="{i18n>colMaktx}" />
                        </Column>

                        <Column hAlign="Center">
                            <Text text="{i18n>colRunDate}" />
                        </Column>

                        <Column>
                            <Text text="{i18n>colErnam}" />
                        </Column>

                        <!-- 최초 승인대기일: WA 아이템 최소 주차일 -->
                        <!-- WA 아이템 없으면 빈값 표시 -->
                        <Column hAlign="Center">
                            <Text text="{i18n>colEarliestWaDate}" />
                        </Column>

                        <Column hAlign="Center">
                            <Text text="{i18n>colErdat}" />
                        </Column>
                    </columns>

                    <items>
                        <!-- 행 클릭 시 onRowPress → RouteDetail navTo -->
                        <ColumnListItem
                            type="Navigation"
                            press=".onRowPress"
                        >
                            <cells>
                                <!-- 상태 LED -->
                                <!-- statusIcon: EC=circle-task-2/EF=error/CN=sys-minus -->
                                <!-- statusState: EC=Information/EF=Error/CN=None -->
                                <ObjectStatus
                                    icon="{
                                        parts: [
                                            {path: 'mainTableModel>Status'},
                                            {path: 'mainTableModel>EarliestWaDate'}
                                        ],
                                        formatter: '.formatter.statusIcon'
                                    }"
                                    state="{
                                        parts: [
                                            {path: 'mainTableModel>Status'},
                                            {path: 'mainTableModel>EarliestWaDate'}
                                        ],
                                        formatter: '.formatter.statusState'
                                    }"
                                />

                                <!-- 상태상세 -->
                                <!-- headerToItemStatusText: EC=확정포함/EF,CN=계획취소 -->
                                <!-- statusState 재사용: EC=Information/EF=Error/CN=None -->
                                <ObjectStatus
                                    text="{
                                        parts: [
                                            {path: 'mainTableModel>Status'},
                                            {path: 'mainTableModel>EarliestWaDate'}
                                        ],
                                        formatter: '.formatter.headerToItemStatusText'
                                    }"
                                    state="{
                                        parts: [
                                            {path: 'mainTableModel>Status'},
                                            {path: 'mainTableModel>EarliestWaDate'}
                                        ],
                                        formatter: '.formatter.statusState'
                                }"
                                />

                                <!-- 실행상태 텍스트: statusText formatter -->
                                <ObjectStatus
                                    text="{path: 'mainTableModel>Status', formatter: '.formatter.statusText'}"
                                    state="{path: 'mainTableModel>Status', formatter: '.formatter.statusTextState'}"
                                />

                                <!-- MPS 실행 ID: Link 클릭 시 onRowPress 호출 -->
                                <Link
                                    text="{mainTableModel>MpsRunId}"
                                    press=".onRowPress"
                                    wrapping="true"
                                />

                                <!-- 날짜: formatDate formatter → yyyy.MM.dd -->
                                <Text
                                    text="{path: 'mainTableModel>PlanStartDate', formatter: '.formatter.formatDate'}"
                                />
                                <Text
                                    text="{path: 'mainTableModel>PlanEndDate', formatter: '.formatter.formatDate'}"
                                />

                                <Text text="{mainTableModel>Werks}" />
                                <Text text="{mainTableModel>PlantName}" />
                                <Text text="{mainTableModel>Matnr}" />
                                <Text text="{mainTableModel>Maktx}" />

                                <Text
                                    text="{path: 'mainTableModel>RunDate', formatter: '.formatter.formatDate'}"
                                />
                                <Text text="{mainTableModel>Ernam}" />

                                <!-- EarliestWaDate: null이면 빈값 표시 -->
                                <Text
                                    text="{path: 'mainTableModel>EarliestWaDate', formatter: '.formatter.formatEarliestWaDate'}"
                                />
                                <Text
                                    text="{path: 'mainTableModel>Erdat', formatter: '.formatter.formatDate'}"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
